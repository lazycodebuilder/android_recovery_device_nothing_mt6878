on post-fs
    # Start the service responsible for any pre-symlink logic
    start create_pl_dev

    # Wait for actual device-mapper block nodes to appear
    wait /dev/block/mapper/pl_a
    wait /dev/block/mapper/pl_b

    # Symlinks to standardized names (via pl_a/pl_b)
    symlink /dev/block/mapper/pl_a /dev/block/by-name/preloader_raw_a
    symlink /dev/block/mapper/pl_b /dev/block/by-name/preloader_raw_b

    symlink /dev/block/mapper/pl_a /dev/block/platform/bootdevice/by-name/preloader_raw_a
    symlink /dev/block/mapper/pl_b /dev/block/platform/bootdevice/by-name/preloader_raw_b

    # FSTAB_RAW2(lk2,bootloader2) of fstab.in.emmc, but without bootloader2 mount point
    symlink /dev/block/by-name/lk1 /dev/block/by-name/bootloader1
    symlink /dev/block/by-name/lk2 /dev/block/by-name/bootloader2

    # Additional platform-specific symlinks
    symlink /dev/block/mapper/pl_a /dev/block/platform/soc/112b0000.ufshci/by-name/preloader_raw_a
    symlink /dev/block/mapper/pl_b /dev/block/platform/soc/112b0000.ufshci/by-name/preloader_raw_b

    symlink /dev/block/mapper/pl_a /dev/block/platform/112b0000.ufshci/by-name/preloader_raw_a
    symlink /dev/block/mapper/pl_b /dev/block/platform/112b0000.ufshci/by-name/preloader_raw_b

# Service that may help prepare device-mapper or other early setups
service create_pl_dev /system/bin/create_pl_dev
    user root
    group root
    seclabel u:r:update_engine:s0
    oneshot
    disabled
