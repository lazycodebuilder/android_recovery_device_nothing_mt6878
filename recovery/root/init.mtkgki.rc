# Enhanced module loading service for recovery
service insmod_sh /system/bin/init.insmod.sh /system/etc/init.insmod.mt6878.cfg 5
    class core
    user root
    group root system
    disabled
    oneshot
    seclabel u:r:recovery:s0

# Backup service in case main service fails
service insmod_fallback /system/bin/init.insmod.sh /system/etc/init.insmod.mt6878.cfg 1
    class late_start
    user root
    group root system
    disabled
    oneshot
    seclabel u:r:recovery:s0

on early-init
    # Initialize module loading status
    setprop vendor.all.modules.ready 0
    setprop vendor.modules.loading 0
    setprop vendor.recovery.modules.loaded 0

    # Create necessary directories
    mkdir -p /lib/modules 0755 root root
    mkdir -p /vendor/lib/modules 0755 root root

    # Set up logging
    write /proc/bootprof "modprobe: Load_Module_START"

    # Ensure script has proper permissions
    chmod 0755 /system/bin/init.insmod.sh

    # Start module loading
    start insmod_sh

on property:vendor.all.modules.ready=1
    write /proc/bootprof "modprobe: Load_Module_END"
    setprop vendor.module.loading.status "completed"

on property:vendor.all.modules.ready=0 && property:sys.boot_completed=1
    # If modules aren't ready after boot, try fallback
    start insmod_fallback

# Recovery-specific triggers
on property:ro.bootmode=recovery
    setprop vendor.recovery.mode 1
    # Additional recovery-specific module loading if needed

# Timeout handler - if modules don't load in 60 seconds, continue anyway
on property:sys.boot.timeout=true
    setprop vendor.all.modules.ready 1
    setprop vendor.module.loading.status "timeout"

# Debug service for troubleshooting
service module_debug /system/bin/sh -c "lsmod > /tmp/loaded_modules.txt; getprop | grep vendor.*.modules > /tmp/module_props.txt"
    class main
    user root
    group root
    disabled
    oneshot
    seclabel u:r:recovery:s0